# OpenAI — enables live GHOST narration. Optional: the stub AI responder
# works without a key. Same variable name works locally and on Vercel.
#
# Local dev:  cp .env.example .env.local   (then paste your key — never commit it)
# Vercel:     Project Settings → Environment Variables → OPENAI_API_KEY
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
