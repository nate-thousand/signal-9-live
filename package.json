    "bootstrap": "^5.0.2",
    "plantasia-sound-engine": "file:../plantasonic-platform/packages/sound-engine",
    "plantasonic-design-system": "file:../plantasonic-xyz/plantasonic-design-system"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "sass": "^1.89.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
