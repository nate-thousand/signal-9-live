{
  "name": "signal-9-broadcast-terminal",
  "version": "0.1.0",
  "private": true,
  "description": "Signal 9 — AI-first interactive broadcast terminal on Plantasonic Platform.",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "validate": "node scripts/validate-app.mjs"
  },
  "dependencies": {
    "@plantasonic/platform": "file:../plantasonic-platform/packages/sdk",
    "@plantasonic/platform-types": "file:../plantasonic-platform/packages/shared-types",
